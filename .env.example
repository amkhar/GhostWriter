# GhostWriter environment variables
# Copy this file to .env and fill in your values.

# ============================================================================
# LLM Provider Configuration
# ============================================================================
# Choose your LLM provider: bedrock, gcp, azure
LLM_PROVIDER=bedrock

# ============================================================================
# AWS Bedrock Provider (default)
# ============================================================================
# AWS region for Bedrock
AWS_REGION=us-east-1

# Bedrock model ID — must support tool use (e.g. Claude 3 Sonnet, Claude 3.5 Sonnet)
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0

# AWS credentials — use the standard AWS credential chain:
#   Option 1: IAM role (recommended for EC2/Lambda)
#   Option 2: ~/.aws/credentials profile
#   Option 3: explicit env vars below
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key
# AWS_SESSION_TOKEN=your_session_token  # if using temporary credentials

# Legacy: Bedrock API key (alternative to AWS credentials)
# BEDROCK_API_KEY=your_bedrock_api_key

# ============================================================================
# Google Cloud Platform (GCP) Provider
# ============================================================================
# Uncomment and configure if using GCP:
# LLM_PROVIDER=gcp
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_LOCATION=us-central1
# GCP_MODEL_ID=claude-3-5-sonnet@20241022

# Authentication (one of the following):
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# OR run on GCP with default service account
# OR run 'gcloud auth application-default login'

# Required packages:
# pip install google-cloud-aiplatform google-auth

# ============================================================================
# Microsoft Azure OpenAI Provider
# ============================================================================
# Uncomment and configure if using Azure:
# LLM_PROVIDER=azure
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_azure_api_key
# AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
# AZURE_MODEL_ID=gpt-4o

# ============================================================================
# Box Configuration (required for all providers)
# ============================================================================
# Box developer token (from Box Developer Console → OAuth 2.0 → Developer Token)
# For production, replace with CCG (Client Credentials Grant) credentials:
#   BOX_CLIENT_ID_A=<your_client_id>
#   BOX_SECRET_A=<your_client_secret>
BOX_TOKEN=your_box_developer_token_here

# Optional: Box root folder ID (default "0" = root)
# BOX_ROOT_FOLDER_ID=0

# ============================================================================
# Voice Recording (optional - only for 'record' command)
# ============================================================================
# Deepgram API key for voice recording (free $200 credit at https://console.deepgram.com)
# DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ============================================================================
# Task Enrichment (optional)
# ============================================================================
# Apify API token (https://console.apify.com/account/integrations)
# Optional: enables public-sentiment task prioritization + dependency-bump
# compatibility checks. The pipeline runs normally (no enrichment) when unset.
# APIFY_TOKEN=your_apify_token_here
# APIFY_SEARCH_ACTOR=apify~google-search-scraper  # override the search actor (optional)